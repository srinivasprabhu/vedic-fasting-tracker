{
  "expo": {
    "backgroundColor": "#0a0604",
    "name": "Aayu: Intermittent Fasting",
    "shortName": "Aayu",
    "slug": "vedic-intermittent-fasting",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aayu-fasting",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5E8D2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vedicintermittentfasting.app",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Aayu",
        "CFBundleName": "Aayu",
        "NSMotionUsageDescription": "Aayu uses motion data to automatically count your steps and help you reach your daily activity target.",
        "NSHealthShareUsageDescription": "Aayu reads your steps, weight, and active energy to enhance your fasting insights and show your progress in one place."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5E8D2"
      },
      "package": "com.vedicintermittentfasting.app",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "sounds": []
        }
      ],
      "expo-router",
      "expo-font",
      "@sentry/react-native/expo",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.174313447601-brnan6k03ufofi4oa6ask4g4k3tf0hl1"
        }
      ],
      [
        "react-native-health",
        { "isClinicalDataEnabled": false }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      "./plugins/withHealthConnect"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d3434280-b838-48ad-b763-529ba87b2693"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d3434280-b838-48ad-b763-529ba87b2693"
    }
  }
}
